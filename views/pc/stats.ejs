<!DOCTYPE html>
<html lang="ko">

<head>
    <%- include("../layout/head") %>
    <style>
        .recentCharTabs {
            display: flex;
            gap: 8px;
            align-items: center;
            flex-wrap: wrap;
        }

        .recentCharTab {
            border: 1px solid #cfd6df;
            background: #f3f6f9;
            color: #4a5563;
            border-radius: 999px;
            padding: 8px 14px;
            font-size: 14px;
            font-weight: 700;
            line-height: 1;
            transition: background-color 0.15s ease, color 0.15s ease, border-color 0.15s ease, box-shadow 0.15s ease;
        }

        .recentCharTab:hover {
            background: #e7edf3;
            border-color: #b9c4d1;
        }

        .recentCharTab.active {
            background: #1f2937;
            border-color: #1f2937;
            color: #fff;
            box-shadow: 0 6px 18px rgba(31, 41, 55, 0.18);
        }

        .recentCharPanel {
            margin-top: 14px;
        }

        .recentLeaderCell {
            text-align: left;
        }

        .recentLeaderRateBest {
            color: #1d4ed8;
            font-weight: 700;
        }

        .recentLeaderRateWorst {
            color: #dc2626;
            font-weight: 700;
        }

        #recent30CharRateMeta,
        #recent7CharRateMeta {
            margin-bottom: 10px;
            color: #667085;
            font-size: 13px;
        }
    </style>
    <script src="/js/charImage.js" crossorigin="anonymous"></script>
    <script type="text/javascript">
        const currentSeasonCode = '<%= typeof currentSeasonCode !== "undefined" ? currentSeasonCode : "현재" %>';
        const currentSeasonStartDate = '<%= typeof dataStartDate !== "undefined" ? dataStartDate : "" %>';

        let charData = [];
        let sortBy = "rate";
        let isRateDesc = true;
        let isTotalMatchesDesc = true;

        $(document).ready(function() {
            $("#searchCharName").on("keydown", function(e) {
                if (e.key === "Enter") {
                    e.preventDefault();
                    searchChar();
                }
            });

            $("#sortByWinrate").on("click", toggleCharRate);
            $("#sortByTotalMatches").on("click", toggleTotalMatches);
            $(".recentCharTab").on("click", switchRecentCharTab);

            setDatePicker();
            $("#fromDt").on("change", callCharStats);
            $("#mainMenu").removeClass("active");

            getStats("statsCountList", drawCount);
            getStats("statsRecentCharLeaders", drawRecentCharLeaders);
            callCharStats();
        });

        const callCharStats = () => {
            const day = $("#fromDt").val();
            getStats(`statsCharList?date=${day}`, drawCharFunc);
        };

        const setDatePicker = () => {
            const yesterday = new Date();
            yesterday.setDate(yesterday.getDate() - 1);
            const yesterdayStr = yesterday.toISOString().slice(0, 10);

            $("#fromDt").datepicker({
                uiLibrary: "bootstrap5",
                iconsLibrary: "fontawesome",
                locale: "kr-ko",
                minDate: currentSeasonStartDate,
                value: yesterdayStr,
                format: "yyyy-mm-dd",
                maxDate: yesterday
            });
        };

        const drawCharFunc = (data) => {
            charData = data.row || [];

            const list = [...charData];
            if (sortBy === "rate") {
                list.sort(isRateDesc ? statsPageRateDesc : statsPageRateAsc);
            } else {
                list.sort(isTotalMatchesDesc ? statsPageTotalMatchesDesc : statsPageTotalMatchesAsc);
            }

            const div = $("#charRate");
            div.empty();

            const table = $(`
                <table class="table table-striped table-condensed">
                    <thead class="thead-light">
                        <tr>
                            <th scope="col">순위</th>
                            <th scope="col">캐릭터</th>
                            <th scope="col">판수</th>
                            <th scope="col">승</th>
                            <th scope="col">패</th>
                            <th scope="col">승률</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            `);

            const tbody = table.find("tbody");

            if (list.length === 0) {
                tbody.append("<tr><td colspan='6'>데이터가 없습니다.</td></tr>");
            } else {
                list.forEach((item, index) => {
                    const number = ((sortBy === "rate" && !isRateDesc) || (sortBy === "totalMatches" && !isTotalMatchesDesc))
                        ? list.length - index
                        : index + 1;

                    tbody.append(`
                        <tr>
                            <td>${number}</td>
                            <td><img data-item='${item.char_name}' src='https://img-api.neople.co.kr/cy/characters/${charMap.get(item.char_name)}' alt="${item.char_name}"></td>
                            <td>${Number(item.total_matches).toLocaleString()}</td>
                            <td>${Number(item.win_count).toLocaleString()}</td>
                            <td>${Number(item.lose_count).toLocaleString()}</td>
                            <td>${item.rate}%</td>
                        </tr>
                    `);
                });
            }

            div.append(table);
            searchChar();
        };

        const drawRecentCharLeaders = (data) => {
            (data.row || []).forEach((periodData) => {
                drawRecentCharLeaderTable(periodData.periodDays, periodData.list || [], periodData.latestRankDate);
            });
            setActiveRecentCharTab("7");
        };

        const drawRecentCharLeaderTable = (periodDays, list, latestRankDate) => {
            const targetId = periodDays === 30 ? "recent30CharRate" : "recent7CharRate";
            const div = $("#" + targetId);
            div.empty();

            if (latestRankDate) {
                $("#" + targetId + "Meta").text(`대표 유저 기준: ${latestRankDate} 랭킹 600위 이내`);
            }

            const table = $(`
                <table class="table table-striped table-condensed">
                    <thead class="thead-light">
                        <tr>
                            <th scope="col">순위</th>
                            <th scope="col">캐릭터</th>
                            <th scope="col">전체 전적</th>
                            <th scope="col">전체 승률</th>
                            <th scope="col">대표 유저 5명(6판 이상)</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            `);

            const tbody = table.find("tbody");

            if (list.length === 0) {
                tbody.append("<tr><td colspan='5'>데이터가 없습니다.</td></tr>");
            } else {
                list.forEach((item, index) => {
                    const visibleLeaders = (item.leaders || []).filter((leader) => Number(leader.player_matches) > 5);
                    const qualifiedLeaders = visibleLeaders;
                    const qualifiedRates = qualifiedLeaders.map((leader) => Number(leader.player_rate));
                    const bestRate = qualifiedRates.length > 0 ? Math.max(...qualifiedRates) : null;
                    const worstRate = qualifiedRates.length > 0 ? Math.min(...qualifiedRates) : null;

                    const leaders = visibleLeaders.length > 0
                        ? visibleLeaders.map((leader) => `
                            <div>
                                랭킹 ${leader.rank_number}위 / ${leader.player_matches}전 ${leader.player_win_count}승 ${leader.player_lose_count}패 / ${buildLeaderRateHtml(leader, bestRate, worstRate)}
                            </div>
                        `).join("")
                        : "<div>조건에 맞는 유저 없음</div>";

                    tbody.append(`
                        <tr>
                            <td>${index + 1}</td>
                            <td><img data-item='${item.char_name}' src='https://img-api.neople.co.kr/cy/characters/${charMap.get(item.char_name)}' alt="${item.char_name}"></td>
                            <td>${Number(item.total_matches).toLocaleString()}전 ${Number(item.win_count).toLocaleString()}승 ${Number(item.lose_count).toLocaleString()}패</td>
                            <td>${item.rate}%</td>
                            <td class="recentLeaderCell">${leaders}</td>
                        </tr>
                    `);
                });
            }

            div.append(table);
        };

        const buildLeaderRateHtml = (leader, bestRate, worstRate) => {
            const rate = Number(leader.player_rate);
            const matches = Number(leader.player_matches);

            if (matches <= 5 || bestRate == null || worstRate == null) {
                return `${rate}%`;
            }

            if (rate === bestRate && rate === worstRate) {
                return `${rate}%`;
            }

            if (rate === bestRate) {
                return `<span class="recentLeaderRateBest">${rate}%</span>`;
            }

            if (rate === worstRate) {
                return `<span class="recentLeaderRateWorst">${rate}%</span>`;
            }

            return `${rate}%`;
        };

        const switchRecentCharTab = function() {
            setActiveRecentCharTab($(this).data("period"));
        };

        const setActiveRecentCharTab = (period) => {
            $(".recentCharTab").removeClass("active");
            $(`.recentCharTab[data-period='${period}']`).addClass("active");
            $(".recentCharPanel").hide();
            $(`#recentCharPanel${period}`).show();
        };

        const toggleCharRate = () => {
            if (sortBy !== "rate") {
                isRateDesc = true;
            } else {
                isRateDesc = !isRateDesc;
            }

            sortBy = "rate";
            drawCharFunc({ row: charData });
            $("#sortByWinrate").removeClass("disabled").toggleClass("rotate");
            $("#sortByTotalMatches").addClass("disabled").removeClass("rotate");
        };

        const toggleTotalMatches = () => {
            if (sortBy !== "totalMatches") {
                isTotalMatchesDesc = true;
            } else {
                isTotalMatchesDesc = !isTotalMatchesDesc;
            }

            sortBy = "totalMatches";
            drawCharFunc({ row: charData });
            $("#sortByTotalMatches").removeClass("disabled").toggleClass("rotate");
            $("#sortByWinrate").addClass("disabled").removeClass("rotate");
        };

        const searchChar = () => {
            const keyword = ($("#searchCharName").val() || "").toLowerCase();
            const rows = $("#charRate table tbody tr");

            rows.each(function() {
                const charName = $(this).find("td:eq(1) img").attr("data-item") || "";
                $(this).toggle(charName.includes(keyword));
            });
        };

        const statsPageRateDesc = (a, b) => Number(b.rate) - Number(a.rate);
        const statsPageRateAsc = (a, b) => Number(a.rate) - Number(b.rate);
        const statsPageTotalMatchesDesc = (a, b) => Number(b.total_matches) - Number(a.total_matches);
        const statsPageTotalMatchesAsc = (a, b) => Number(a.total_matches) - Number(b.total_matches);

        const drawCount = (data) => {
            const div = $("#statsCountDiv");
            div.empty();

            const table = "<table class='table table-bordered table-striped'>";
            const tr = "<thead><tr>";
            const tbody = "<tbody><tr>";
            const endTbody = "</tr></tbody></table>";

            let th = "";
            let td = "";
            let trCount = 1;
            let first = true;

            for (idx in data.row) {
                const item = data.row[idx];
                th += "<th>" + replaceEngToKo(item.dates) + "</th>";
                td += "<td>" + toDisplayNumber(item.cnt) + "</td>";

                if (trCount % 7 === 0) {
                    const newTable = table + tr + th + tbody + td + endTbody;
                    th = "";
                    td = "";
                    if (first) {
                        $("#statsCountDiv").append(newTable);
                        first = false;
                    } else {
                        $("#moreCountDiv").append(newTable);
                    }
                }

                trCount++;
            }

            if (first) {
                const newTable = table + tr + th + tbody + td + endTbody;
                $("#statsCountDiv").append(newTable);
            }
        };

        function replaceEngToKo(date) {
            return date
                .replace("Monday", "월")
                .replace("Tuesday", "화")
                .replace("Wednesday", "수")
                .replace("Thursday", "목")
                .replace("Friday", "금")
                .replace("Saturday", "토")
                .replace("Sunday", "일");
        }

        function toDisplayNumber(value) {
            const normalized = String(value ?? "0").replace(/,/g, "");
            const parsed = Number(normalized);
            return Number.isFinite(parsed) ? parsed.toLocaleString() : "0";
        }

        function getStats(url, callback) {
            $.ajax({
                async: true,
                url: "/stats/" + url,
                success: function(data) {
                    if (data.resultCode === -1) {
                        return;
                    }
                    callback(data);
                },
                error: function() {
                    return;
                }
            });
        }
    </script>
</head>

<body class="body renewalBody">
<%- include("../layout/menu") %>

<div id="statsMain" class="mainLayout">
    <%- include("../layout/rightBanner") %>

    <div class="playCounter">
        <h3>주간 공식 집계 판수 <i class="fas fa-angle-double-down" data-bs-toggle="collapse" data-bs-target="#moreCountDiv" aria-expanded="true"></i></h3>
        <div class="line"></div>
        <div id="statsCountDiv"></div>
        <div id="moreCountDiv" class="collapse"></div>
    </div>

    <div class="listWrapper">
        <article id="con1">
            <div class="charSearchWrapper">
                <h3>최근 캐릭터 승률</h3>
                <div class="charWinRate">
                    <h5>
                        <span class="recentCharTabs">                            
                            <button type="button" class="recentCharTab active" data-period="7">최근 7일</button>
                            <button type="button" class="recentCharTab" data-period="30">최근 30일</button>
                        </span>
                    </h5>
                </div>
            </div>
            <div class="line"></div>
            <section id="recentCharPanel30" class="recentCharPanel" style="display:none;">
                <p id="recent30CharRateMeta"></p>
                <div id="recent30CharRate"></div>
            </section>
            <section id="recentCharPanel7" class="recentCharPanel">
                <p id="recent7CharRateMeta"></p>
                <div id="recent7CharRate"></div>
            </section>
        </article>

        <article id="con3">
            <div class="charSearchWrapper">
                <h3>캐릭터 승률</h3>
                <div class="charSearch">
                    <label for="searchCharName"><span class="searchIcon"></span></label>
                    <input type="text" id="searchCharName" placeholder="캐릭터명 검색" />
                </div>
            </div>
            <div class="line"></div>
            <section>
                <div class="season2025U">
                    <h4><%= currentSeasonCode %> 현황</h4>
                    <div class="charWinRate">
                        <h5>
                            <button type="button" id="sortByWinrate">승률순<span class="arrow"></span></button>
                            <button type="button" id="sortByTotalMatches" class="disabled">판수순<span class="arrow"></span></button>
                        </h5>
                    </div>
                    <div class="dateWrap" style="margin-bottom:12px;">
                        <input type="text" id="fromDt" />
                    </div>
                    <div id="charRate"></div>
                </div>
            </section>
        </article>
    </div>
</div>

</body>
</html>
