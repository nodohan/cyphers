<!DOCTYPE html>
<html lang="ko">

<head>
    <%- include("../layout/head") %>
    <script src="/js/charImage.js" crossorigin="anonymous"></script>
    <script type="text/javascript">
        pageName = "pcCounter";

        $(document).ready(function () {
            $("#mainMenu").removeClass("active");
            $("#userCounterMenu").addClass("active");
        });

        function userCounter() {
            if ($("#nickName").val().trim() === '') {
                alert("닉네임을 입력해주세요.");
                return;
            }

            getUserCounter($("#nickName").val());
        }

        const getUserCounter = (nickname) => {
            ajaxCall("/userDetail/selectUserDetail", { nickname }, callCounter);
        };

        const callCounter = (result) => {
            const userDetail = result.rows[0];
            if (userDetail == null) {
                insertUserDetail();
                return;
            }

            drawCountInfo(result.nickname, userDetail);
            if (userDetail.complateDate != null) {
                drawCounterItems(userDetail);
            }
        };

        const drawCountInfo = (nickname, userDetail) => {
            if (userDetail.complateDate != null) {
                return;
            }

            let resultMsg = "접수되었습니다.";
            switch (userDetail.state) {
                case "insert":
                    resultMsg = "접수되었습니다.";
                    break;
                case "reserve":
                    resultMsg = "대기중입니다.";
                    break;
                case "running":
                    resultMsg = "분석중입니다.";
                    break;
                case "complate":
                    return;
            }
            alert(resultMsg);
        };

        const insertUserDetail = () => {
            ajaxCall("/userDetail/insertUserDetail", { nickname: $("#nickName").val() }, alterInfo);
        };

        const isYesterday = (dateString) => {
            const yesterday = new Date();
            yesterday.setDate(yesterday.getDate() - 1);
            return dateString.substring(0, 10) === yesterday.toISOString().substring(0, 10);
        };

        const drawCounterItems = (data) => {
            let refreshButton = "";
            if (data.state === "complate" && !isYesterday(data.complateDate)) {
                refreshButton = `<button type="button" class="btn specialGhostBtn" onClick="javascript:insertUserDetail();">재분석</button>`;
            }

            $(".userCountSpan").html(`
                <div class="specialMetaLine">
                    <span class="specialMetaBadge">수집일 ${data.complateDate.substring(0, 10)}</span>
                    ${refreshButton}
                </div>
            `);

            $("#con1_1").empty();
            $("#con1_2").empty();
            $("#con2_1").empty();
            $("#con2_2").empty();

            const user = JSON.parse(data.playerDetail);
            const char = JSON.parse(data.charDetail);

            drawUserCounter($("#con1_1"), user.myTeam);
            drawUserCounter($("#con1_2"), user.enemyTeam);
            drawCharCounter($("#con2_1"), char.myTeam);
            drawCharCounter($("#con2_2"), char.enemyTeam);
        };

        const alterInfo = () => {
            alert("해당 기능은 데이터 수집과 분석에 시간이 필요합니다.\n최소 2분에서 최대 1시간 후 다시 확인해주세요.");
        };

        const drawUserCounter = (div, rows) => {
            const min = Number($("#min").val() || 3);
            const clone = $("#templateTable").clone();
            clone.removeAttr("id");
            clone.find("th:first").text("닉네임");

            const body = clone.find("tbody");
            rows.sort(counterRateDesc);

            rows.filter(row => (row.win + row.lose) >= min).forEach(row => {
                body.append(
                    `<tr>
                        <td><b>${row.nickname}</b></td>
                        <td>${row.win}승</td>
                        <td>${row.lose}패</td>
                        <td>${((row.win * 100) / (row.win + row.lose)).toFixed(0)}%</td>
                    </tr>`
                );
            });

            if (!body.children().length) {
                body.append(`<tr><td colspan="4">조건에 맞는 전적이 없습니다.</td></tr>`);
            }

            div.append(clone);
        };

        const drawCharCounter = (div, rows) => {
            const clone = $("#templateTable").clone();
            clone.find("th:first").text("캐릭터");
            clone.removeAttr("id");

            const body = clone.find("tbody");
            const transArr = Object.entries(rows).map(item => ({
                win: item[1].win,
                lose: item[1].lose,
                charName: item[0]
            }));

            transArr.sort(counterRateDesc);

            transArr.forEach(row => {
                body.append(
                    `<tr>
                        <td><b>${row.charName}</b></td>
                        <td>${row.win}승</td>
                        <td>${row.lose}패</td>
                        <td>${((row.win * 100) / (row.win + row.lose)).toFixed(0)}%</td>
                    </tr>`
                );
            });

            if (!body.children().length) {
                body.append(`<tr><td colspan="4">조건에 맞는 전적이 없습니다.</td></tr>`);
            }

            div.append(clone);
        };

        const counterRateDesc = (a, b) => ((b.win * 100) / (b.win + b.lose)) - ((a.win * 100) / (a.win + a.lose));
    </script>
</head>

<body class="body renewalBody specialPage">
    <%- include("../layout/menu") %>

    <div id="statsMain" class="mainLayout specialPageLayout">
        <%- include("../layout/rightBanner") %>

        <section class="playCounter specialHero">
            <div class="specialHeroText">
                <p class="specialEyebrow">SPECIAL MENU</p>
                <h3>상대 전적 분석</h3>
                <p>같은 팀, 상대 팀, 캐릭터 기준 상성을 한 번에 정리하는 분석형 페이지입니다.</p>
            </div>
            <div class="specialSearchPanel">
                <div class="specialCounterSearchRow">
                    <input type="text" id="nickName" class="form-control specialInput" placeholder="닉네임"
                        aria-label="닉네임" onKeyPress="if(event.keyCode == 13) { userCounter(); }">
                    <input type="number" id="min" class="form-control specialInput specialNumberInput" placeholder="최소 판수"
                        aria-label="최소 판수">
                    <button class="btn specialActionBtn" type="button" onClick="userCounter();">분석</button>
                </div>
                <p class="specialHint">공식전 데이터를 기반으로 집계되며, 최초 요청 시 분석 작업이 등록됩니다.</p>
            </div>
        </section>

        <section class="specialPanel">
            <div class="specialPanelHeader specialPanelHeaderRow">
                <div>
                    <p class="specialPanelEyebrow">PLAYER COUNTER</p>
                    <h4>유저 상성</h4>
                </div>
                <div class="userCountSpan"></div>
            </div>
            <div class="specialQuadGrid">
                <section class="specialSubPanel">
                    <h5>같은 팀</h5>
                    <div id="con1_1" class="specialTableWrap table-responsive">
                        <div class="specialEmptyState">분석이 완료되면 같은 팀 기준 승패 비율이 표시됩니다.</div>
                    </div>
                </section>
                <section class="specialSubPanel">
                    <h5>상대 팀</h5>
                    <div id="con1_2" class="specialTableWrap table-responsive">
                        <div class="specialEmptyState">상대 팀에서 자주 마주친 닉네임이 정렬됩니다.</div>
                    </div>
                </section>
            </div>
        </section>

        <section class="specialPanel">
            <div class="specialPanelHeader">
                <p class="specialPanelEyebrow">CHARACTER COUNTER</p>
                <h4>캐릭터 상성</h4>
            </div>
            <div class="specialQuadGrid">
                <section class="specialSubPanel">
                    <h5>같은 팀</h5>
                    <div id="con2_1" class="specialTableWrap table-responsive">
                        <div class="specialEmptyState">함께 플레이했을 때의 캐릭터 궁합이 여기에 표시됩니다.</div>
                    </div>
                </section>
                <section class="specialSubPanel">
                    <h5>상대 팀</h5>
                    <div id="con2_2" class="specialTableWrap table-responsive">
                        <div class="specialEmptyState">상대 진영에서 강하거나 약한 캐릭터를 확인할 수 있습니다.</div>
                    </div>
                </section>
            </div>
        </section>
    </div>

    <div style="display:none">
        <table id="templateTable" class="counterTable table table-striped">
            <thead class="thead-dark">
                <tr>
                    <th scope="col"></th>
                    <th scope="col">승리</th>
                    <th scope="col">패배</th>
                    <th scope="col">승률</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</body>

</html>
