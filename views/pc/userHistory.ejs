<!DOCTYPE html>
<html lang="ko">

<head>
    <%- include("../layout/head") %>
    <script type="text/javascript">
        $(document).ready(function () {
            $("#mainMenu").removeClass("active");
            $("#userHistory").addClass("active");

            ajaxCall("/history/getUserSearchRank", null, drawRank);
            fetchPunishedUsers();
        });

        function fetchPunishedUsers() {
            $.ajax({
                url: "/history/punishedUsers",
                success: function (data) {
                    let html = "";
                    if (!data || data.length === 0) {
                        html = "<div class='specialEmptyState'>기록이 없습니다.</div>";
                    } else {
                        data.forEach(row => {
                            html += `
                                <article class="historyTimelineItem">
                                    <strong>${row.punish_date}</strong>
                                    <p>${row.nickname} - ${row.reason}</p>
                                </article>
                            `;
                        });
                    }
                    $("#punishedUserList").html(html);
                }
            });
        }

        function drawRank(data) {
            const tbody = $("#searchRankTable").find("tbody");
            tbody.empty();
            $("#dueSpan").text(`(${data.startDate} ~ ${data.endDate})`);

            if (!data.rows.length) {
                tbody.append("<tr><td colspan='3'>검색 기록이 없습니다.</td></tr>");
                return;
            }

            data.rows.forEach((row, index) => {
                const nicknameLink = `<a href="#" onClick="javascript:searchRankUser('${row.nickname}'); return false;">${row.nickname}</a>`;
                tbody.append(`<tr><td>${index + 1}</td><td>${nicknameLink}</td><td>${row.cnt}</td></tr>`);
            });
        }

        function searchRankUser(userName) {
            $("#nickNames").val(userName.trim());
            searchNicknameHistory("Y");
        }

        function searchNicknameHistory(byRank = "N") {
            const val = $("#nickNames").val().trim();
            if (val === "") {
                alert("검색어를 입력해주세요.");
                return;
            } else if (val.length >= 9) {
                alert("닉네임은 최대 8자리까지 가능합니다.");
                return;
            }

            ajaxNicknameHistory(val, byRank);
        }

        function ajaxNicknameHistory(nickName, byRank) {
            $.ajax({
                async: false,
                url: "/history/searchNicknameHistory",
                data: {
                    nickname: nickName,
                    byRank: byRank
                },
                success: function (data) {
                    $("#nickNames").val("");

                    if (data.resultCode == -1) {
                        alert(nickName + "의 정보가 없습니다.");
                        return;
                    }
                    if (data.resultCode == -2) {
                        alert("요청자에 의해 비공개 처리되었습니다.");
                        return;
                    }

                    drawHistory(nickName, data);
                },
                error: function () {
                    alert(nickName + "의 정보가 없습니다.");
                }
            });
        }

        function drawHistory(nickName, data) {
            if (data.length === 0) {
                alert("수집된 기록이 없습니다.");
                return;
            }

            $("#historyResult").empty();
            $("#historyResultTitle").text(`조회 결과 · ${nickName}`);

            const historyTable = $("#templateTable").clone();
            historyTable.attr("id", "");

            let resultTable = "";
            for (idx in data) {
                const row = data[idx];
                resultTable += `<tr><td>${row[1]}</td><td>${row[0]}</td></tr>`;
            }

            historyTable.find("tbody").append(resultTable);
            $("#historyResult").append(historyTable);
        }
    </script>
</head>

<body class="body renewalBody specialPage">
    <%- include("../layout/menu") %>

    <div id="statsMain" class="mainLayout specialPageLayout historyPageLayout">
        <%- include("../layout/rightBanner") %>

        <section class="playCounter specialHero">
            <div class="specialHeroText">
                <p class="specialEyebrow">SPECIAL MENU</p>
                <h3>닉네임 이력 조회</h3>
                <p>※ 닉네임 비공개 요청은, 공지 게시판의 양식에 맞춰서 신청해주시기 바랍니다. </p>
                <p>※ 추가 비공개는 개인별 신청일로부터 6개월마다 재신청 받아 지원합니다. (트롤/어뷰징/욕설 노상관)</p>
            </div>
            <div class="specialSearchPanel">
                <div class="specialCounterSearchRow specialCounterSearchRowCompact">
                    <input type="text" class="form-control specialInput" id="nickNames"
                        onKeyPress="if(event.keyCode == 13) { searchNicknameHistory(); }"
                        placeholder="조회할 닉네임" aria-label="조회할 닉네임">
                    <button class="btn specialActionBtn" type="button" onClick="searchNicknameHistory();">검색</button>
                </div>
            </div>
        </section>

        <section class="specialHistoryGrid">
            <article class="specialPanel">
                <div class="specialPanelHeader">
                    <p class="specialPanelEyebrow">SEARCH RESULT</p>
                    <h4 id="historyResultTitle">조회 결과</h4>
                </div>
                <div id="historyResult" class="specialTableWrap specialScrollable">
                    <div class="specialEmptyState">조회 결과가 여기에 표시됩니다.</div>
                </div>
            </article>

            <article class="specialPanel">
                <div class="specialPanelHeader">
                    <p class="specialPanelEyebrow">TRENDING SEARCH</p>
                    <h4>최근 닉네임 검색 순위</h4>
                    <p class="specialHint">최근 3일 기준 <span id="dueSpan"></span></p>
                </div>
                <div class="specialTableWrap specialScrollable">
                    <table id="searchRankTable" class="table table-striped table-condensed">
                        <thead class="thead-dark">
                            <tr>
                                <th scope="col">순위</th>
                                <th scope="col">닉네임</th>
                                <th scope="col">검색 횟수</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td colspan="3">검색 기록이 없습니다.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </article>

            <article class="specialPanel">
                <div class="specialPanelHeader">
                    <p class="specialPanelEyebrow">RE OPEN LIST</p>
                    <h4>비공개 해지 이력</h4>
                    <p class="specialHint">요청 또는 운영 사유로 공개가 제한된 닉네임 목록입니다.</p>
                </div>
                <div id="punishedUserList" class="specialScrollable historyTimeline">
                    <div class="specialEmptyState">기록이 없습니다.</div>
                </div>
            </article>
        </section>
    </div>

    <div id="template" class="infoDiv" style="display:none">
        <table id="templateTable" class="table table-striped table-condensed">
            <thead class="thead-dark">
                <tr>
                    <th scope="col">수집일</th>
                    <th scope="col">닉네임</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</body>

</html>
