            }
            .userSearchRenewal .teamRateBlue,
            .userSearchRenewal .teamRateRed {
                display: inline-flex;
                margin: 10px 0 0;
                padding: 7px 12px;
                border-radius: 999px;
                font-size: 13px;
                font-weight: 700;
                background: rgba(255, 255, 255, 0.9);
                border: 1px solid rgba(120, 136, 160, 0.18);
            }
            .userSearchRenewal #con1 .input-group,
            .userSearchRenewal #con2 .input-group,
            .userSearchRenewal #con3 .input-group {
                margin-top: 12px;
                background: #fff;
                border-radius: 14px;
                border: 1px solid rgba(120, 136, 160, 0.18);
                box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.75);
                overflow: hidden;
            }
            .userSearchRenewal #nickNames,
            .userSearchRenewal #nickNames3 {
                background: rgba(224, 237, 255, 0.72);
            }
            .userSearchRenewal #nickNames2 {
                background: rgba(255, 235, 235, 0.72);
            }
            .userSearchRenewal .input-group > .form-control {
                box-sizing: border-box;
                border: 0;
                min-height: 46px;
                padding: 0 14px;
                font-size: 14px;
                box-shadow: none;
            }
            .userSearchRenewal .input-group-append {
                display: flex;
                gap: 8px;
                padding: 6px;
                background: #fff;
            }
            .userSearchRenewal .input-group-append .btn {
                box-sizing: border-box;
                border: 0;
                min-width: 76px;
                border-radius: 10px;
                font-weight: 700;
                color: #fff;
            }
            .userSearchRenewal .searchBtnPrimary {
                background: #343a40;
            }
            .userSearchRenewal .searchBtnSecondary {
                background: #8a94a6;
            }
            .userSearchRenewal .infoLayer {
                margin-top: 12px;
                height: calc(100% - 94px);
                background: transparent;
            }
            .userSearchRenewal .userSearchCard {
                box-sizing: border-box;
                border: 1px solid rgba(103, 150, 217, 0.22);
                border-radius: 18px;
                background: linear-gradient(180deg, rgba(237, 244, 255, 0.98) 0%, rgba(223, 235, 255, 0.98) 100%);
                box-shadow: 0 14px 26px rgba(65, 105, 180, 0.12);
                padding: 10px 12px 12px;
                margin-bottom: 8px;
            }
            .userSearchRenewal .infoDivRed.userSearchCard {
                border-color: rgba(222, 138, 138, 0.26);
                background: linear-gradient(180deg, rgba(255, 243, 243, 0.98) 0%, rgba(255, 231, 231, 0.98) 100%);
                box-shadow: 0 14px 26px rgba(202, 83, 83, 0.1);
            }
            .userSearchRenewal .nicknameLayer {
                display: flex;
                align-items: center;
                gap: 6px;
                flex-wrap: wrap;
                border-bottom: 1px solid rgba(120, 136, 160, 0.22);
                padding-bottom: 8px !important;
                margin-bottom: 8px;
            }
            .userSearchRenewal .nickNameDiv {
                min-width: auto;
                height: auto;
                font-size: 24px;
                line-height: 1.1;
                letter-spacing: -0.03em;
                color: #24324a;
            }
            .userSearchRenewal .width45p,
            .userSearchRenewal .width50p {
                display: flex;
                align-items: center;
                gap: 4px;
                flex-wrap: wrap;
                font-size: 13px;
            }
            .userSearchRenewal #playGameDiv {
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 8px 10px;
                margin: 4px 0 6px;
                background: rgba(255, 255, 255, 0.72);
                border-radius: 12px;
                font-size: 13px;
            }
            .userSearchRenewal #playGameDiv p {
                margin: 0;
            }
            .userSearchRenewal .playParty {
                padding: 8px 10px;
                border-radius: 12px;
                background: rgba(255, 255, 255, 0.62);
                font-size: 13px;
            }
            .userSearchRenewal .positionDiv,
            .userSearchRenewal .mostCharDiv,
            .userSearchRenewal .recentlyDiv {
                margin-top: 8px;
                padding: 8px 10px;
                border-radius: 12px;
                background: rgba(255, 255, 255, 0.62);
            }
            .userSearchRenewal .positionDiv {
                display: grid;
                grid-template-columns: repeat(2, minmax(0, 1fr));
                gap: 6px;
            }
            .userSearchRenewal .positionDiv .card,
            .userSearchRenewal .mostCharDetailDiv .card {
                border: 0;
                border-radius: 10px;
                box-shadow: none;
            }
            .userSearchRenewal #mostCharTitleDiv,
            .userSearchRenewal #recentlyDivTitle {
                font-weight: 700;
                color: #33415c;
                font-size: 13px;
            }
            .userSearchRenewal .tack,
            .userSearchRenewal .tackRemove {
                margin-left: auto;
            }
            .rank-info-box {
                display: flex;
                align-items: center;
                background: linear-gradient(135deg, #fff5f0 0%, #fff 100%);
                border: 1px solid #ffd8c4;
                border-radius: 8px;
                padding: 8px 15px;
                margin-top: 10px;
                margin-bottom: 5px;
                box-shadow: 0 2px 4px rgba(255, 69, 0, 0.05);
                width: max-content;
            }
            .rank-info-text {
                display: flex;
                align-items: baseline;
                margin-right: 15px;
            }
            .rank-label {
                font-size: 0.8em;
                color: #888;
                font-weight: 600;
                letter-spacing: -0.5px;
            }
            .rank-value {
                font-size: 1.2em;
                color: #ff4500;
                font-weight: bold;
                margin-top: 2px;
            }
            .rank-diff {
                font-size: 0.85em;
                margin-top: 2px;
                font-weight: 500;
            }
            .rank-diff.up {
                color: #ff4d4f;
            }
            .rank-diff.down {
                color: #1890ff;
            }
            .rank-diff.stay {
                color: #8c8c8c;
            }
            .rank-sparkline-svg {
                vertical-align: middle;
                overflow: visible;
            }
        </style>
        <script type="text/javascript">
            pageName = "pcUserSearch";

            var userData = {};

            $(document).ready(function() {
                let nickname = '<%=searchNickname%>';
                if (nickname != '') {
                    $("#nickNames").val(nickname);
                    search('nickNames', 'con1_2');
                }

                showSearchHistory();
                $("#partyShow").on("change", () => checkVisibility("partyShow"));
                $("#positionShow").on("change", () => checkVisibility("positionShow"));
                $("#mostCharShow").on("change", () => checkVisibility("mostCharShow"));
                $("#recentShow").on("change", () => checkVisibility("recentShow"));
                $("#tackShow").on("change", () => tackUse());
                $("input[name='gameType']").on("change", syncGameTypeButtons);
                tackUse();
                syncGameTypeButtons();

                resetGameType();
                $("input[name='gameType']").on("change", resetGameType);
            });

            function syncGameTypeButtons() {
                $("input[name='gameType']").each(function() {
                    $(this).closest("label.btn").toggleClass("active", this.checked);
                });
            }

            function resetGameType() {
                const val = $("input[name='gameType']:checked").val();
                clearDiv('con1_2');
                clearDiv('con2_2');
                $(".gameTypeText").text(val == 'rating' ? '[공식전]' : '[일반전]');
                syncGameTypeButtons();

                // modalDiv의 자식 div 중 id가 templateModal이 아닌 것을 찾아 삭제
                $('#modalDiv > div:not(#templateModal)').remove();
                userData = {};

                Cookies.set('gameType', val, {
                    expires: 7
                });
            }

            function getCookie() {
                setCheckbox('partyShow', Cookies.get('playParty'));
                setCheckbox('positionShow', Cookies.get('positionDiv'));
                setCheckbox('mostCharShow', Cookies.get('mostCharDiv'));
                setCheckbox('recentShow', Cookies.get('recentlyDiv'));
                setCheckbox('tackShow', Cookies.get('tackShow'));

                let gameType = Cookies.get('gameType');
                if (gameType == null || gameType == '') {
                    gameType = 'rating';
                }
                $(`input[name='gameType'][value='${gameType}']`).click();
            }

            function setCheckbox(id, checked) {
                checked = (checked == null || checked == 'true' || checked == true);
                const chkbox = $("input:checkbox[id='" + id + "']");
                chkbox.attr("checked", checked);
                chkbox.prop('checked', checked);
            }

            function checkVisibility(id) {
                console.log(id);
                const isShow = $("#" + id).is(":checked");
                setVisible(id, isShow);
                Cookies.set(id, isShow, {
                    expires: 7
                });
            }

            const visibleTackDiv = () => {
                if ($("#tackShow").is(":checked")) {
                    //$("#mainUserSearch").css("width", "88%");
                    //$(".top").css("width", "88%");
                    $("#con3").show();
                } else {
                    // $("#mainUserSearch").css("width", "77%");
                    // $(".top").css("width", "77%");
                    $("#con3").hide();
                }
            }

            const tackUse = () => {
                const checked = $("#tackShow").is(":checked");
                Cookies.set("tackShow", checked, {
                    expires: 30
                });

                visibleTackDiv();
                $(".con").css("width", checked ? "29%": "38%");

                //1. 고정을 사용하는 경우
                if (checked) {
                    let userList = [];
                    if (Cookies.get('tackUserList')) {
                        userList = Cookies.get('tackUserList').split(",");
                    }
                    userList.forEach(divId => {
                        const divItem = $("#" + divId);
                        if (!moveToTack(divId)) {
                            // 이미 존재하는 div인경우 가져와보고
                            // 존재하지 않는 경우 검색
                            let userNm = divId.split("_")[0];
                            $("#nickNames3").val(userNm);
                            search('nickNames3', 'con3_2');
                        }
                    });
                } else {
                    //2. 고정을 사용하지 않는 경우
                    Cookies.set("tackUserList", '', {
                        expires: 30
                    });
                    $("#con3_2").find(".infoDiv").each((index, item) => {
                        $(item).find(".tackRemove").hide();
                        $(item).find(".tack").show();
                        $("#con1_2").prepend(item);
                    });
                }
            };

            const addTackUser = (divId) => {
                updateTackCookie(divId, "add");
                visibleTackDiv();
                moveToTack(divId);
            }

            const removeTackUser = (divId) => {
                updateTackCookie(divId, "remove");
                $("#" + divId).remove();
            }

            const updateTackCookie = (divId, action) => {
                let userList = [];
                if (Cookies.get('tackUserList')) {
                    userList = Cookies.get('tackUserList').split(",");
                }

                const isShow = action == "add";
                const index = userList.indexOf(divId);
                if (action == "add") {
                    if (index < 0) {
                        userList.push(divId);
                    }
                } else if (action == "remove") {
                    if (index >= 0) {
                        userList.splice(index, 1);
                    }
                }

                setCheckbox("tackShow", isShow);
                Cookies.set("tackShow", isShow, {
                    expires: 30
                });
                Cookies.set("tackUserList", userList.join(","), {
                    expires: 30
                });
            }

            const moveToTack = (divId) => {
                const divItem = $("#" + divId);
                if (divItem.length != 0) {
                    divItem.find(".tackRemove").show();
                    divItem.find(".tack").hide();
                    $("#con3").find("#con3_2").prepend(divItem);
                }
                return divItem.length != 0;
            }

            function setVisible(classId, isShow) {
                let div = $("." + classId);
                isShow ? div.show() : div.hide();
            }

            function setUserInfo(gameType, divName, data) {
                const nickname = data.nickname;
                if (userData[nickname] == null) {
                    userData[nickname] = data;
                }

                if(gameType == 'rating') {
                    const { playerId } = data;
                    callTeamRate(playerId, divName == "con1_2" ? "blue" : "red", drawTeamRate);

                    drawRatingUserInfo(gameType, divName, data, nickname);
                } else {
                    drawNormalUserInfo(gameType, divName, data, nickname);
                }
            }

            const drawTeamRate  = (team, data) => {
                console.log("data", data);
                const divId  = team == "blue" ? "teamRateBlue" : "teamRateRed" ;
                const {rate, total} = data;
                $("."+divId).empty().text(`팀승률: ${total}전 승률:${rate} `);
            }

            const drawRatingUserInfo = (gameType, divName, data, nickname) => {
                var userDivId = getUserDivId(gameType, nickname);
                if ($("#" + userDivId).length != 0) {
                    return;
                }

                //기본 정보 
                var clone = $("#template").clone();
                clone.attr("id", userDivId);
                if (divName == "con2_2") {
                    clone.removeClass("infoDiv");
                    clone.addClass("infoDivRed");
                }

                defaultInfo(userDivId, gameType, clone, data, divName != "con3_2");

                var rows = data.matches.rows.filter(row => row.playInfo.playTypeName == "정상" || row.playInfo.result == "승리" ).sort((a, b) => new Date(b.date) - new Date(a.date));
                //printChar(rows);

                //파티별
                drawPartyType(userDivId, clone.find("#playParty"), rows);

                //포지션별 
                getUserPositionInfo(data.playerId, clone.find("#positionDiv"));
                //drawPosition(clone, rows, nickname, appendPlayTypeInfo);

                //최근 10경기 결과
                drawRecently(clone, rows, userDivId);

                //자주하는 캐릭
                var userChar = extractChar(rows, sortCase);
                drawOften(clone, userChar, drawCharCardVer, nickname);

                clone.show();
                $("#" + divName).prepend(clone);
            }

            const getUserPositionInfo = (playerId, div) => {
                var result;
                $.ajax({
                    async: true,
                    url: "/matchesMap/getMatchesMap",
                    data: {"playerId" : playerId},
                    success: function(data) {
                        try {
                            callLoadingBar(false);
                        } catch (e) {

                        }
                        setUserPosition(div, data);
                    },
                    error: function(data) {
                        if (typeof callLoadingBar == 'function') {
                            callLoadingBar(false);
                        }
                        return;
                    }
                }).done(function() {
                    if (typeof callLoadingBar == 'function') {
                        callLoadingBar(false);
                    }
                });
            }

            const setUserPosition = (div, data) => {
                const emptyObj = { "win_count" : 0, "lose_count" : 0, "total_games" : 0};
                drawUserPosition(div, "극방",  data.filter(item => item.POSITION === "극방")[0] || emptyObj); 
                drawUserPosition(div, "방벨",  data.filter(item => item.POSITION === "방벨")[0] || emptyObj);                 
                drawUserPosition(div, "공벨",  data.filter(item => item.POSITION === "공벨")[0] || emptyObj); 
                drawUserPosition(div, "극공",  data.filter(item => item.POSITION === "극공")[0] || emptyObj); 
            }

            const drawUserPosition = (div, type, data) => {
                let imgUrl = "/image/position/";
                switch(type){
                    case "극방" : imgUrl += "defence.png";  break;
                    case "방벨" : imgUrl += "defenceBal.png";  break;
                    case "공벨" : imgUrl += "attackBal.png";  break;
                    case "극공" : imgUrl += "attack.png";  break;
                }

                const {win_count, lose_count, total_games} = data;
                const winRate = ((win_count / total_games) * 100) || 0;
                const infoStr = `${winRate.toFixed(2)}% <br><small class='text-muted'>${win_count}승 ${lose_count}패</small>`;

                $(div).append(`
                    <div class="card">
                        <div class="row no-gutters">
                            <div class="col-md-4">
                                <img src="${imgUrl}">
                            </div>
                            <div class="col-md-8">
                                <div class="card-body">
                                    <p id="tankerSpan" class="card-text">${infoStr}</p>
                                </div>
                            </div>
                        </div>
                    </div>`);
            }

            const drawNormalUserInfo = (gameType, divName, data, nickname) => {
                var userDivId = getUserDivId(gameType, nickname);
                if ($("#" + userDivId).length != 0) {
                    return;
                }

                //기본 정보 
                var clone = $("#template").clone();
                clone.attr("id", userDivId);
                if (divName == "con2_2") {
                    clone.removeClass("infoDiv");
                    clone.addClass("infoDivRed");
                }

                defaultInfoNormal(userDivId, gameType, clone, data, divName != "con3_2");

                var rows = data.matches.rows.filter(row => row.playInfo.playTypeName == "정상" || row.playInfo.result == "승리" ).sort((a, b) => new Date(b.date) - new Date(a.date));
                //printChar(rows);

                //파티별
                drawPartyTypeNormal(userDivId, clone.find("#playParty"), rows);

                //포지션별 
                //drawPositionNormal(clone, rows, data.nickname);

                //자주하는 캐릭
                var userChar = extractChar(rows, sortCase);
                drawOftenNormal(clone, userChar, nickname);

                //최근 10경기 결과
                drawRecentlyNormal(clone, rows, userDivId);

                clone.show();
                $("#" + divName).prepend(clone);
            }

            function defaultInfo(divId, gameType, clone, data, tackShow) {
                var rating = data.records.filter(game => game.gameTypeId == gameType)[0] || { loseCount: 0, stopCount: 0, winCount: 0 };
                var pov = ((rating.winCount * 100) / (rating.winCount + rating.loseCount)) || 0;
                let item = $(clone);

                item.find("#nickNameDiv").append(data.nickname);
                item.find("#nickNameDiv").append(` <a href='javascript:nickHistory("${data.playerId}");' ><i class='red fas fas fa-heading'></i></a>`);
                item.find("#levelDiv").text(data.grade + "급 ");
                item.find("#clanDiv").text(data.clanName);

                getTierColerName(item.find("#tierName"), data.tierName);
                if (data.ratingPoint != null) {
                    item.find("#currRP").text(data.ratingPoint);
                    item.find("#maxRP").text("(" + data.maxRatingPoint + ")");
                }
                
                // 최신 랭킹 표시 및 히스토리 차트
                if (data.latestRank) {
                    item.find("#rankBadgeContainer").show();
                    const rankVal = typeof data.latestRank === 'object' ? data.latestRank.rank : data.latestRank;
                    item.find("#latestRankDiv").text(`${rankVal}위`);
                    
                    if (typeof data.latestRank === 'object' && data.latestRank.rankDiff !== null) {
                        const diff = data.latestRank.rankDiff;
                        let diffText = "";
                        let diffClass = "";
                        
                        if (diff > 0) {
                            diffText = `▲${diff}`;
                            diffClass = "up";
                        } else if (diff < 0) {
                            diffText = `▼${Math.abs(diff)}`;
                            diffClass = "down";
                        } else {
                            diffText = " - ";
                            diffClass = "stay";
                        }
                        item.find("#rankDiffDiv").text(diffText).removeClass("up down stay").addClass(diffClass);
                    }
                }
                
                if (data.rankHistory && data.rankHistory.length > 1) {
                    const sparkline = createRankSparkline(data.rankHistory);
                    item.find("#rankChartDiv").html(sparkline);
                } else {
                    item.find("#rankChartDiv").empty();
                }

                item.find("#beforeSeason").append(`<a href='javascript:userSeasonRank("${data.playerId}", drawSeasonRank);' >전시즌</a>`);

                let tot = rating.winCount + rating.loseCount + rating.stopCount;
                item.find("#playGameDiv").append(`<b class="red">승률</b> : ${pov.toFixed(0)}% [${tot}전 ${rating.winCount}승 ${rating.loseCount}패 ${rating.stopCount}중단]`);
                item.find("#tack").on("click", () => addTackUser(divId));
                item.find(".tackRemove").on("click", () => removeTackUser(divId));
                if (tackShow) {
                    item.find(".tack").show();
                    item.find(".tackRemove").hide();
                } else {
                    item.find(".tack").hide();
                    item.find(".tackRemove").show();
                }

            }

            function createRankSparkline(history) {
                const width = 120;
                const height = 35;
                const padding = 4;
                
                const ranks = history.map(h => h.rankNumber);
                const minRank = Math.min(...ranks);
                const maxRank = Math.max(...ranks);
                const range = maxRank - minRank || 1;
                
                const points = history.map((h, i) => {
                    const x = (i / (history.length - 1)) * (width - padding * 2) + padding;
                    // 랭킹은 낮을수록(1위에 가까울수록) 위에 그려야 하므로 Y축 계산 주의
                    const y = ((h.rankNumber - minRank) / range) * (height - padding * 2) + padding;
                    return `${x},${y}`;
                });
                
                const pointsStr = points.join(" ");
                
                // 영역 그라데이션을 위한 path 데이터 생성
                let pathD = `M ${padding},${height} `;
                pathD += points.map((p, i) => (i === 0 ? `L ${p}` : `L ${p}`)).join(" ");
                const lastX = points[points.length-1].split(',')[0];
                const lastY = points[points.length-1].split(',')[1];
                pathD += ` L ${lastX},${height} Z`;
                
                return `
                    <svg width="${width}" height="${height}" class="rank-sparkline-svg">
                        <defs>
                            <linearGradient id="rankGradient" x1="0%" y1="0%" x2="0%" y2="100%">
                                <stop offset="0%" stop-color="#ff4500" stop-opacity="0.3" />
                                <stop offset="100%" stop-color="#ff4500" stop-opacity="0.0" />
                            </linearGradient>
                        </defs>
                        <path d="${pathD}" fill="url(#rankGradient)" />
                        <polyline points="${pointsStr}" fill="none" stroke="#ff4500" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                        <circle cx="${lastX}" cy="${lastY}" r="3" fill="#fff" stroke="#ff4500" stroke-width="1.5" />
                    </svg>
                `;
            }

            function drawSeasonRank(data) {
                if (data.length == 0) {
                    alert("전시즌 언랭");
                } else {
                    let rankText = data.map(row => `${row.season} ${row.rankNumber == '몰?루?' ? '몰?루?' : row.rankNumber}위 `).join("\n");
                    alert(rankText);
                }
            }

            function getTierColerName(span, tierName) {
                let name = tierName;
                if (name == null) {
                    name = "Unrank";
                }
                span.addClass(name);
                span.text(name);
            }

            function nickHistory(nickId) {
                historyNickname(nickId, showNickHistory);
            }

            function showNickHistory(data) {
                if (data.length == 0 || data.resultCode == -1) {
                    alert("수집된 닉변기록이 없습니다");
                    return;
                }

                let info = "";
                for (idx in data) {
                    let row = data[idx];
                    info += row.season + ", " + row.nickname + ", 체크일:" + row.checkingDate + "\n";
                }

                alert(info);
            }

            $(function () {
                const $dropZone = $('#drop-zone');
                const $result = $('#result');

                // 드래그 오버
                $dropZone.on('dragover', function (e) {
                    e.preventDefault();
                    e.stopPropagation();
                    $(this).addClass('dragover');
                });

                // 드래그 리브
                $dropZone.on('dragleave', function (e) {
                    e.preventDefault();
                    e.stopPropagation();
                    $(this).removeClass('dragover');
                });

                // 드롭
                $dropZone.on('drop', function (e) {
                    e.preventDefault();
                    e.stopPropagation();
                    $(this).removeClass('dragover');

                    const file = e.originalEvent.dataTransfer.files[0];
                    if (!file) return;

                    // 미리보기 또는 업로드 처리
                    uploadImage(file);
                });

                function uploadImage(file) {
                const formData = new FormData();
                formData.append('image', file);

                $result.text('업로드 중...');

                $.ajax({
                    url: '/user/getOcrNames',
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function (data) {
                        inferSearch(data.teamA.join(" "), 'con1_2');
                        inferSearch(data.teamB.join(" "), 'con2_2');
                    },
                    error: function (xhr, status, err) {
                        console.error(err);
                        $result.text('업로드 실패 😥');
                    }
                });
                }
            });

            const inferSearch = (nicknames, divId)  => {
                if (nicknames && nicknames != "") {
                    $("#nickNames").val(nicknames);
                    search('nickNames', divId);
                }
            }

        </script>
</head>

