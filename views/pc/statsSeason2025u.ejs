<!DOCTYPE html>
<html lang="ko">

<head>
    <%- include("../layout/head") %>
    <script src="/js/charImage.js" crossorigin="anonymous"></script>
    <script type="text/javascript">
        let season = '<%= season %>';

        $(document).ready(function () {
            $("#seasonSelect").val(season);
            refreshData();

            $("#seasonSelect").on("change", function () {
                season = $("#seasonSelect").val();
                window.history.replaceState({}, "", `/stats/stats${season.toLowerCase()}`);
                refreshData();
            });
        });

        const refreshData = () => {
            season = $("#seasonSelect").val();
            $("#seasonOverview").empty();
            $("#topWinRate, #topTotalMatches, #hiddenOp, #trap").empty();
            $(".seasonStatsEyebrow").text(`${season} Season Stats`);
            $(".seasonStatsTitle").text(`${season} 별도 집계 통계`);
            getStats(drawSeasonSummary);
        };

        const getStats = (callback) => {
            $.ajax({
                async: true,
                url: "/stats/stats2025uSummary",
                data: { season: season },
                success: function (data) {
                    callback(data.row || {});
                },
                error: function () {
                    $("#seasonOverview").html("<p>집계 데이터가 없습니다. 먼저 배치를 실행해주세요.</p>");
                }
            });
        };

        const drawSeasonSummary = (data) => {
            drawOverview(data.overview || {}, data.thresholds || {});
            drawStatsListDiv("topWinRate", data.topWinRate || [], "캐릭터 승률");
            drawStatsListDiv("topTotalMatches", data.topTotalMatches || [], "캐릭터 픽수");
            drawStatsListDiv("hiddenOp", data.hiddenOp || [], "히든 OP");
            drawStatsListDiv("trap", data.trap || [], "함정 캐릭터");
        };

        const drawOverview = (overview) => {
            const rows = [
                {
                    label: "시즌 총 경기 수",
                    value: formatNumber(overview.totalMatches)
                },
                {
                    label: "평균 게임 시간",
                    value: formatDuration(overview.avgDuration)
                }
            ];

            const table = $(`
                <div class="seasonOverviewTable">
                    <div class="seasonOverviewHead seasonOverviewRow">
                        <span>항목</span>
                        <span>값</span>
                    </div>
                </div>
            `);

            rows.forEach((row) => {
                table.append(`
                    <div class="seasonOverviewRow">
                        <strong class="seasonOverviewLabel">${row.label}</strong>
                        <span class="seasonOverviewValue">${row.value}</span>
                    </div>
                `);
            });

            $("#seasonOverview").append(table);
        };

        const drawStatsListDiv = (divId, rows, title) => {
            const section = $(`
                <section class="seasonTableSection">
                    <div class="seasonPanelHeader">
                        <h4>${title}</h4>
                    </div>
                </section>
            `);

            const table = $("#seasonTableTemplate").clone();
            table.removeAttr("id");

            const tbody = table.find("tbody");
            if (!rows.length) {
                tbody.append("<tr><td colspan='7'>데이터가 없습니다.</td></tr>");
            }

            rows.forEach((row, index) => {
                tbody.append(`
                    <tr>
                        <td>${index + 1}</td>
                        <td>${getChars([row.charName])}</td>
                        <td>${row.charName}</td>
                        <td>${formatNumber(row.totalMatches)}</td>
                        <td>${formatNumber(row.winCount)}</td>
                        <td>${formatNumber(row.loseCount)}</td>
                        <td>${Number(row.winRate || 0).toFixed(2)}%</td>
                    </tr>
                `);
            });

            section.append(table);
            $("#" + divId).append(section);
        };

        const getChars = (arr) => {
            const names = (arr || []).filter(Boolean);

            if (!names.length) {
                return "<span class='seasonStatsEmpty'>정보 없음</span>";
            }

            return names.map((name) => {
                const charId = charMap.get(name);
                if (!charId) {
                    return `<span class="seasonStatsEmpty">${name}</span>`;
                }

                return `<img data-item="${name}" src="https://img-api.neople.co.kr/cy/characters/${charId}" alt="${name}">`;
            }).join("");
        };

        const formatNumber = (value) => Number(value || 0).toLocaleString();

        const formatDuration = (seconds) => {
            if (seconds == null) {
                return "-";
            }

            const totalSeconds = Number(seconds || 0);
            const minutes = Math.floor(totalSeconds / 60);
            const remainSeconds = totalSeconds % 60;
            return `${minutes}분 ${String(remainSeconds).padStart(2, "0")}초`;
        };
    </script>
</head>

<body class="body renewalBody">
    <%- include("../layout/menu") %>

    <div id="statsMain" class="mainLayout seasonStatsPage seasonStatsWidePage">
        <%- include("../layout/rightBanner") %>

        <section class="playCounter seasonStatsHero">
            <div class="seasonStatsHeroText">
                <p class="seasonStatsEyebrow"><%= season %> Season Stats</p>
                <h3 class="seasonStatsTitle"><%= season %> 별도 집계 통계</h3>
                <p>저장 원본을 직접 조회하지 않고 집계 테이블 결과만 보여줍니다.</p>
            </div>
            <div class="seasonStatsControl">
                <label for="seasonSelect">시즌 선택</label>
                <select id="seasonSelect" class="form-select">
                    <option value="2025H">2025H</option>
                    <option value="2025U">2025U</option>
                </select>
            </div>
        </section>

        <section class="seasonPanel">
            <div class="seasonPanelHeader">
            </div>
            <div id="seasonOverview"></div>
        </section>

        <section class="seasonPanel seasonTabbedPanel">
            <div class="seasonPanelHeader">
            </div>

            <nav>
                <div class="nav nav-tabs seasonTabs" role="tablist">
                    <a class="nav-link active" data-bs-toggle="tab" href="#seasonWinRateTab" role="tab" aria-selected="true">승률</a>
                    <a class="nav-link" data-bs-toggle="tab" href="#seasonPickTab" role="tab" aria-selected="false">픽수</a>
                    <a class="nav-link" data-bs-toggle="tab" href="#seasonHiddenOpTab" role="tab" aria-selected="false">히든 OP</a>
                    <a class="nav-link" data-bs-toggle="tab" href="#seasonTrapTab" role="tab" aria-selected="false">함정 캐릭터</a>
                </div>
            </nav>

            <div class="tab-content seasonTabContent">
                <div class="tab-pane fade show active" id="seasonWinRateTab" role="tabpanel">
                    <article id="topWinRate" class="seasonPanel"></article>
                </div>
                <div class="tab-pane fade" id="seasonPickTab" role="tabpanel">
                    <article id="topTotalMatches" class="seasonPanel"></article>
                </div>
                <div class="tab-pane fade" id="seasonHiddenOpTab" role="tabpanel">
                    <article id="hiddenOp" class="seasonPanel"></article>
                </div>
                <div class="tab-pane fade" id="seasonTrapTab" role="tabpanel">
                    <article id="trap" class="seasonPanel"></article>
                </div>
            </div>
        </section>
    </div>

    <div style="display:none">
        <table id="seasonTableTemplate" class="table table-striped table-condensed">
            <thead class="thead-light">
                <tr>
                    <th scope="col">순위</th>
                    <th scope="col">이미지</th>
                    <th scope="col">캐릭터</th>
                    <th scope="col">픽수</th>
                    <th scope="col">승</th>
                    <th scope="col">패</th>
                    <th scope="col">승률</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</body>

</html>
