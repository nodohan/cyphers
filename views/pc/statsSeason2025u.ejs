<!DOCTYPE html>
<html lang="ko">

<head>
    <%- include("../layout/head") %>
    <script src="/js/charImage.js" crossorigin="anonymous"></script>
    <script type="text/javascript">
        let season = '<%= season %>';

        $(document).ready(function () {
            $("#seasonSelect").val(season);
            refreshData();
            $("#seasonSelect").on("change", refreshData);
        });

        const refreshData = () => {
            season = $("#seasonSelect").val();
            $("#seasonOverview, #topWinRate, #topTotalMatches, #hiddenOp, #trap").empty();
            getStats(drawSeasonSummary);
        };

        const getStats = (callback) => {
            $.ajax({
                async: true,
                url: "/stats/stats2025uSummary",
                data: { season: season },
                success: function (data) {
                    callback(data.row || {});
                },
                error: function () {
                    $("#seasonOverview").html("<p>집계 데이터가 없습니다. 먼저 배치를 실행하세요.</p>");
                }
            });
        };

        const drawSeasonSummary = (data) => {
            drawOverview(data.overview || {}, data.thresholds || {});
            drawStatsListDiv("topWinRate", data.topWinRate || [], "캐릭 승률 TOP20");
            drawStatsListDiv("topTotalMatches", data.topTotalMatches || [], "캐릭 판수 TOP20");
            drawStatsListDiv("hiddenOp", data.hiddenOp || [], "숨은 OP");
            drawStatsListDiv("trap", data.trap || [], "함정 캐릭");
        };

        const drawOverview = (overview, thresholds) => {
            const cards = [
                {
                    label: "시즌 총 경기 수",
                    value: formatNumber(overview.totalMatches),
                    desc: "집계 완료된 시즌 경기 수"
                },
                {
                    label: "평균 게임 시간",
                    value: formatDuration(overview.avgDuration),
                    desc: "matches.duration 기준 평균"
                },
                {
                    label: "승률 집계 최소 판수",
                    value: formatNumber(thresholds.minMatches),
                    desc: "숨은 OP, 함정 캐릭 포함 공통 기준"
                },
                {
                    label: "숨은 OP 제외 판수 순위",
                    value: formatNumber(thresholds.hiddenOpExcludeRank),
                    desc: "판수 상위권 캐릭은 숨은 OP에서 제외"
                }
            ];

            const wrap = $("<div class='seasonOverviewGrid'></div>");
            cards.forEach((card) => {
                wrap.append(`
                    <article class="seasonOverviewCard">
                        <p class="seasonOverviewLabel">${card.label}</p>
                        <strong class="seasonOverviewValue">${card.value}</strong>
                        <p class="seasonOverviewDesc">${card.desc}</p>
                    </article>
                `);
            });

            $("#seasonOverview").append(wrap);
        };

        const drawStatsListDiv = (divId, rows, title) => {
            const section = $(`
                <section class="seasonTableSection">
                    <div class="seasonPanelHeader">
                        <h4>${title}</h4>
                    </div>
                </section>
            `);
            const table = $("#seasonTableTemplate").clone();
            table.removeAttr("id");

            const tbody = table.find("tbody");
            if (!rows.length) {
                tbody.append("<tr><td colspan='7'>데이터가 없습니다.</td></tr>");
            }

            rows.forEach((row, index) => {
                tbody.append(`
                    <tr>
                        <td>${index + 1}</td>
                        <td>${getChars([row.charName])}</td>
                        <td>${row.charName}</td>
                        <td>${formatNumber(row.totalMatches)}</td>
                        <td>${formatNumber(row.winCount)}</td>
                        <td>${formatNumber(row.loseCount)}</td>
                        <td>${Number(row.winRate || 0).toFixed(2)}%</td>
                    </tr>
                `);
            });

            section.append(table);
            $("#" + divId).append(section);
        };

        const getChars = (arr) => {
            const names = (arr || []).filter(Boolean);

            if (!names.length) {
                return "<span class='seasonStatsEmpty'>정보 없음</span>";
            }

            return names.map((name) => {
                const charId = charMap.get(name);
                if (!charId) {
                    return `<span class="seasonStatsEmpty">${name}</span>`;
                }

                return `<img data-item="${name}" src="https://img-api.neople.co.kr/cy/characters/${charId}" alt="${name}">`;
            }).join("");
        };

        const formatNumber = (value) => Number(value || 0).toLocaleString();

        const formatDuration = (seconds) => {
            if (seconds == null) {
                return "-";
            }

            const totalSeconds = Number(seconds || 0);
            const minutes = Math.floor(totalSeconds / 60);
            const remainSeconds = totalSeconds % 60;
            return `${minutes}분 ${String(remainSeconds).padStart(2, "0")}초`;
        };
    </script>
</head>

<body class="body renewalBody">
    <%- include("../layout/menu") %>

    <div id="statsMain" class="mainLayout seasonStatsPage">
        <%- include("../layout/rightBanner") %>

        <section class="playCounter seasonStatsHero">
            <div class="seasonStatsHeroText">
                <p class="seasonStatsEyebrow">2025U Season Stats</p>
                <h3><%= season %> 별도 집계 통계</h3>
                <p>원장 직접 조회가 아니라 집계 테이블 결과만 표시합니다.</p>
            </div>
            <div class="seasonStatsControl">
                <label for="seasonSelect">시즌 선택</label>
                <select id="seasonSelect" class="form-select">
                    <option value="2025U">2025U</option>
                </select>
            </div>
        </section>

        <section class="seasonPanel">
            <div class="seasonPanelHeader">
                <h4>시즌 개요</h4>
                <p>배치로 저장된 총 경기 수와 평균 게임 시간입니다.</p>
            </div>
            <div id="seasonOverview"></div>
        </section>

        <div class="listWrapper seasonListWrapper">
            <article id="topWinRate" class="seasonPanel"></article>
            <article id="topTotalMatches" class="seasonPanel"></article>
            <article id="hiddenOp" class="seasonPanel"></article>
            <article id="trap" class="seasonPanel"></article>
        </div>
    </div>

    <div style="display:none">
        <table id="seasonTableTemplate" class="table table-striped table-condensed">
            <thead class="thead-light">
                <tr>
                    <th scope="col">순위</th>
                    <th scope="col">이미지</th>
                    <th scope="col">캐릭터</th>
                    <th scope="col">판수</th>
                    <th scope="col">승</th>
                    <th scope="col">패</th>
                    <th scope="col">승률</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</body>

</html>
