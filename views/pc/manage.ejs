<!DOCTYPE html>
<html lang="ko">

<head>

    <%- include  ("../layout/head") %>
        <script type="text/javascript">
            $(document).ready(function() {
                callLoadingBar(false);

                $("#mainMenu").removeClass("active");
                //$("#combi").addClass("active");
            });

            function callLoadingBar(show) {
                if (show) {
                    $("#loadingbutton").show();
                    $("#searchButton").hide();
                } else {
                    $("#loadingbutton").hide();
                    $("#searchButton").show();
                }
            }

            function searchUser() {
                callLoadingBar(true);

                $.ajax({
                    async: true,
                    url: "/nodo/userNickname",
                    data: {
                        'nickname': $("#nickname").val(),
                    },
                    success: function(data) {
                        callLoadingBar(false);
                        $("#con1_2").empty();

                        if (data.resultCode != 200) {
                            alert(data.resultMsg);
                            return;
                        }
                        drawNicknames(data.row);
                    },
                    error: function(data) {
                        callLoadingBar(false);
                        alert("해당 정보가 없습니다.");
                        return;
                    }
                }).done(function() {
                    callLoadingBar(false);
                });
            }

            function searchUser() {
                callLoadingBar(true);
                const data = {
                    'nickname': $("#nickname").val()
                };

                ajaxCall("/nodo/userNickname", data, (result) => {
                    callLoadingBar(false);
                    $("#con1_2").empty();

                    if(result.player.length != 0) {
                        drawPlayer(result.player, result.row); // 이력(row)도 같이 전달
                    }
                    drawNicknames(result.row);
                });
            }

            function hideNickname() {
                callLoadingBar(true);

                const data = {
                    "playerId": $("#playerId").val(),
                    "reason": $("#reason").val(),
                    "addNickName": $("#addNickName").val()
                };

                ajaxCall("/nodo/hiddenNickName", data, (result) => {
                    callLoadingBar(false);
                    $("#resultNicknames").empty().text(result.resultMsg[0].nicks);
                    searchUser(); // 등록 후 재조회하여 상태 갱신
                });
            }

            const drawPlayer = (player, history) => {
                const now = new Date();
                let statusHtml = "";
                let latestPrivateDate = "";

                // 1. 이력(history)에서 가장 최신 비공개 지원일 찾기
                if (history && history.length > 0) {
                    const hiddenRecords = history.filter(h => h.privateYn === 'Y' && h.privateDate);
                    if (hiddenRecords.length > 0) {
                        // 이미 내림차순 정렬되어 오므로 첫 번째 요소가 가장 최신
                        latestPrivateDate = hiddenRecords[0].privateDate;
                    }
                }

                // 2. 이력에 없으면 관리자 메모(comment)에서 추출 시도
                if (!latestPrivateDate && player[0].comment) {
                    const dateMatch = player[0].comment.match(/(\d{2}-\d{2}-\d{2})/);
                    if (dateMatch) latestPrivateDate = dateMatch[1];
                }
                
                if (latestPrivateDate) {
                    let pDateStr = latestPrivateDate;
                    if (pDateStr.length === 8) pDateStr = "20" + pDateStr; // "25-03-09" -> "2025-03-09"
                    
                    const pDate = new Date(pDateStr);
                    if (!isNaN(pDate.getTime())) {
                        const diffTime = now - pDate;
                        const diffDays = Math.floor(diffTime / (1000 * 60 * 60 * 24));
                        
                        if (diffDays >= 180) {
                            statusHtml = `<div class="alert alert-success mt-2" style="width:100%">
                                            <strong>✅ 변경 가능:</strong> 마지막 비공개(${latestPrivateDate})로부터 <strong>${diffDays}일</strong>이 경과되었습니다. (6개월 통과)
                                          </div>`;
                        } else {
                            const remainingDays = 180 - diffDays;
                            statusHtml = `<div class="alert alert-warning mt-2" style="width:100%">
                                            <strong>⏳ 대기 중:</strong> 마지막 비공개(${latestPrivateDate})로부터 <strong>${diffDays}일</strong> 지났습니다. (약 ${remainingDays}일 후 가능)
                                          </div>`;
                        }
                    }
                } else if (player[0].privateYn === 'N') {
                    statusHtml = `<div class="alert alert-info mt-2" style="width:100%"><strong>ℹ️ 신규 신청 가능:</strong> 비공개 기록이 없는 사용자입니다.</div>`;
                }

                $("#playerDiv").empty().append(`
                    <div style="width:100%">
                        <table class="table table-sm table-bordered mb-1">
                            <tr class="table-secondary"> 
                                <th width="20%" class="text-center">현재상태</th>
                                <th>관리자 메모 (최종 지원일/사유)</th>
                            </tr>
                            <tr> 
                                <td class="text-center"><strong>${player[0].privateYn === 'Y' ? '비공개' : '공개'}</strong></td>
                                <td>${player[0].comment || '-'}</td>
                            </tr>
                        </table>
                        ${statusHtml}
                    </div>`);                
            }

            const drawNicknames = (list) => {
                $("#playerId").val(list[0].playerId);

                let divs = `<div><ul class="list-group">`;
                list.forEach(row => {
                    divs += `<li class="list-group-item"> 
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="checkbox" id="check_${row.nickname}" checked>
                                    <label class="form-check-label" for="check_${row.nickname}">
                                        <strong>${row.nickname}</strong>&nbsp;&nbsp;&nbsp;
                                        <small class="text-muted">/${row.checkingDate}</small>&nbsp;&nbsp;&nbsp;
                                        <span class="badge ${row.privateYn === 'Y' ? 'bg-danger' : 'bg-secondary'}">${row.privateYn === 'Y' ? '비공개' : '공개'}</span>&nbsp;&nbsp;&nbsp;
                                        <small class="text-info">/${row.privateDate || '-'}</small>
                                    </label>
                                </div>
                            </li>
                        `;
                });
                divs += '</ul></div>';

                $("#con1_2").empty().append(divs);
            }
        </script>
</head>

<body class="body">
    <%- include  ("../layout/menu") %>

        <div id="main">

            <div id="con1" class="width45p">
                <h3>사용자명 </h3>
                <div class="input-group mb-3">
                    <input type="text" id="nickname" onKeyPress="if(event.keyCode == 13) { searchUser(); }" class="form-control" placeholder="닉네임" aria-label="닉네임" aria-describedby="searchButton">
                    <div class="input-group-append">
                        <button class="btn btn-outline-secondary" type="button" id="searchButton" onClick="searchUser();">검색</button>
                    </div>
                </div>

                <div class="input-group input-group-default mb-3">
                    <div class="input-group-prepend">
                        <span class="input-group-text" id="inputGroup-sizing-default">playerId</span>
                    </div>
                    <input type="text" id="playerId" class="form-control" aria-label="Sizing example input" aria-describedby="inputGroup-sizing-sm">
                </div>

                <div id="playerDiv" class="input-group input-group-default mb-3">
                    
                </div>

                <div class="input-group input-group-default mb-3">
                    <div class="input-group-prepend">
                        <span class="input-group-text" id="inputGroup-sizing-default">추가될닉네임</span>
                    </div>
                    <input type="text" id="addNickName" class="form-control" aria-label="Sizing example input" aria-describedby="inputGroup-sizing-sm">
                </div>

                <div class="input-group input-group-default mb-3">
                    <div class="input-group-prepend">
                        <span class="input-group-text" id="inputGroup-sizing-default">사유</span>
                    </div>
                    <input type="text" id="reason" class="form-control" aria-label="Sizing example input" aria-describedby="inputGroup-sizing-sm">
                </div>

                <div class="input-group mb-3">
                    <div class="input-group-append">
                        <button class="btn btn-outline-secondary" type="button" id="registButton" onClick="hideNickname();">등록</button>
                    </div>
                </div>

                <label id="resultNicknames" style="background-color: white;"> </label>
                <button id="loadingbutton" class="btn btn-primary" type="button" disabled>
                    <span class="spinner-border spinner-border-default" role="status" aria-hidden="true"></span>
                    Loading...
                </button>
                <div id="con1_2" class="infoLayer" style="height:813px"> </div>
            </div>
        </div>

</body>

</html>