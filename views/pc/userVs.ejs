<!DOCTYPE html>
<html lang="ko">

<head>
    <%- include("../layout/head") %>
    <script type="text/javascript">
        pageName = "pcVs";

        $(document).ready(function () {
            $("#mainMenu").removeClass("active");
            $("#userVsMenu").addClass("active");
        });

        function userVsSearch() {
            if ($("#nickNames").val().trim() === '') {
                alert("첫 번째 닉네임을 입력해주세요.");
                return;
            }

            if ($("#nickNames2").val().trim() === '') {
                alert("상대 닉네임을 입력해주세요.");
                return;
            }

            const result = searchVsUser("rating", $("#nickNames").val(), $("#nickNames2").val());
            drawVs(result);
        }

        function drawVs(result) {
            $("#con1_2").empty();
            $("#con2_2").empty();

            drawTeam("con1_2", result.team);
            drawTeam("con2_2", result.enemy);
        }

        function drawTeam(divId, team) {
            $("#" + divId).append(
                `<h4 class="specialResultSummary">승리: <span class='red'>${team.win}</span> 패배: <span class='blue'>${team.lose}</span></h4>`
            );

            const clone = $("#templateTable").clone();
            clone.removeAttr("id");

            const body = clone.find("tbody");
            const moreIcon = '<i class="fa fa-search-plus" style="font-size:15px;color:black;"></i>';

            team.row.forEach(row => {
                body.append(
                    `<tr>
                        <td>${row.date}</td>
                        <td><b>${winLoseKo(row.result)}</b></td>
                        ${drawInGameScore(row.my)}
                        ${drawInGameScore(row.you)}
                        <td onClick='searchMatch("${row.matchId}", drawMatchVs )'>${moreIcon}</td>
                    </tr>`
                );
            });

            $("#" + divId).append(clone);
        }

        function drawInGameScore(data) {
            return `<td>${drawCharicter(data.charId)}</td>
                    <td class='kda'>${data.kill}/${data.death}/${data.assist}</td>
                    <td class='kda'>${(data.attack / 1000).toFixed(0)}k</td>`;
        }

        function focusMove() {
            $("#nickNames2").focus();
        }

        function drawMatchVs(matchId, result) {
            const prefixMatchId = "m" + matchId;

            if (result == null) {
                const existingModal = document.getElementById(prefixMatchId + "Modal");
                if (existingModal) {
                    bootstrap.Modal.getOrCreateInstance(existingModal).show();
                }
                return;
            }

            let data;
            if (typeof result === "string") {
                data = JSON.parse(result);
            } else {
                data = result;
            }

            const body = $("#templateModal").clone();
            body.attr("id", prefixMatchId + "Modal");
            body.attr("aria-labelledby", prefixMatchId + "ModalLabel");
            body.find("#templateModalLabel")
                .attr("id", prefixMatchId + "ModalLabel")
                .text("매치 상세 " + matchId);
            body.find("#matchInfoTemplate").attr("id", prefixMatchId + "div");

            const tbody = body.find("tbody");
            const winTeam = getTeam(data.teams, "win", data.players);
            const loseTeam = getTeam(data.teams, "lose", data.players);

            for (idx in winTeam) {
                tbody.append(drawInGameDetail(matchId, winTeam[idx], "table-primary"));
            }
            for (idx in loseTeam) {
                tbody.append(drawInGameDetail(matchId, loseTeam[idx], "table-danger"));
            }

            $("#modalDiv").append(body);
            bootstrap.Modal.getOrCreateInstance(body[0]).show();
        }
    </script>
</head>

<body class="body renewalBody specialPage">
    <%- include("../layout/menu") %>

    <div id="statsMain" class="mainLayout specialPageLayout">
        <%- include("../layout/rightBanner") %>

        <section class="playCounter specialHero">
            <div class="specialHeroText">
                <p class="specialEyebrow">SPECIAL MENU</p>
                <h3>갈등을 빚자</h3>
                <p>두 닉네임의 공식전 맞대결 기록만 오피셜하게 비교합니다.</p>
            </div>
            <div class="specialSearchPanel">
                <p class="specialMetaBadge">공식전</p>
                <div class="specialVsSearchRow">
                    <input type="text" id="nickNames" class="form-control specialInput" placeholder="내 닉네임"
                        aria-label="내 닉네임" onKeyPress="if(event.keyCode == 13) { focusMove(); }">
                    <span class="specialInputDivider">VS</span>
                    <input type="text" id="nickNames2" class="form-control specialInput" placeholder="상대 닉네임"
                        aria-label="상대 닉네임" onKeyPress="if(event.keyCode == 13) { userVsSearch(); }">
                    <button class="btn specialActionBtn" type="button" onClick="userVsSearch();">검색</button>
                </div>
            </div>
        </section>

        <section class="specialDualGrid">
            <article id="con1" class="specialPanel specialVsPanel">
                <div class="specialPanelHeader">
                    <p class="specialPanelEyebrow">ALLY SIDE</p>
                    <h4>같은 팀으로 만난 기록</h4>
                </div>
                <div id="con1_2" class="specialTableWrap table-responsive">
                    <div class="specialEmptyState">닉네임 두 개를 입력하면 팀 기준 전적이 여기에 표시됩니다.</div>
                </div>
            </article>

            <article id="con2" class="specialPanel specialVsPanel">
                <div class="specialPanelHeader">
                    <p class="specialPanelEyebrow">ENEMY SIDE</p>
                    <h4>상대 팀으로 만난 기록</h4>
                </div>
                <div id="con2_2" class="specialTableWrap table-responsive">
                    <div class="specialEmptyState">반대 진영에서 만난 기록도 같은 형식으로 정리됩니다.</div>
                </div>
            </article>
        </section>
    </div>

    <div style="display:none">
        <table id="templateTable" class="vsTable table table-striped">
            <thead class="thead-dark">
                <tr>
                    <th scope="col">날짜</th>
                    <th scope="col">결과</th>
                    <th scope="col">내 캐릭터</th>
                    <th scope="col">KDA</th>
                    <th scope="col">공격량</th>
                    <th scope="col">상대 캐릭터</th>
                    <th scope="col">KDA</th>
                    <th scope="col">공격량</th>
                    <th scope="col">상세</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>

    <div id="modalDiv">
        <div id="templateModal" class="modal fade" tabindex="-1" role="dialog" aria-labelledby="templateModalLabel">
            <div class="modal-dialog modal-2xl" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <h6 class="modal-title" id="templateModalLabel"></h6>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">×</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        <table id="matchInfoTemplate" class="table table-striped table-condensed">
                            <thead class="thead-light">
                                <tr>
                                    <th scope="col"></th>
                                    <th scope="col">C</th>
                                    <th scope="col">P</th>
                                    <th scope="col">Buff</th>
                                    <th scope="col">닉네임</th>
                                    <th scope="col">급수</th>
                                    <th scope="col">RP(MAX)</th>
                                    <th scope="col">Lv</th>
                                    <th scope="col">킬</th>
                                    <th scope="col">데스</th>
                                    <th scope="col">어시</th>
                                    <th scope="col">공격</th>
                                    <th scope="col">피해</th>
                                    <th scope="col">치유</th>
                                    <th scope="col">철거</th>
                                    <th scope="col">센티</th>
                                    <th scope="col">코인</th>
                                    <th scope="col">타워(%)</th>
                                    <th scope="col"></th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div hide>
                <a id="matchBtn" data-bs-toggle="modal" data-bs-target=""></a>
            </div>
        </div>
    </div>
</body>

</html>
